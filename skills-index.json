    {
      "id": "persistent-memory",
      "name": "持久记忆系统",
      "category": "自我改进",
      "install": {
        "type": "git",
        "repo": "https://github.com/ChinarG/persistent-memory.git",
        "path": "~/.openclaw/skills/persistent-memory",
        "command": "cd ~/.openclaw/skills && git clone https://github.com/ChinarG/persistent-memory.git && bash persistent-memory/scripts/init.sh",
        "auto_setup": true
      },
      "config": {
        "env_vars": [],
        "files": [
          {
            "path": "~/.openclaw/workspace/memory/",
            "type": "directory",
            "auto_create": true
          },
          {
            "path": "~/.openclaw/workspace/MEMORY.md",
            "type": "file",
            "auto_create": true
          }
        ],
        "cron": {
          "schedule": "0 23 * * *",
          "command": "bash ~/.openclaw/skills/persistent-memory/scripts/save-now.sh"
        }
      },
      "capabilities": ["daily_memory", "long_term_memory", "error_learning"],
      "dependencies": [],
      "multi_device_sync": true
    },
    {
      "id": "claude-code-router",
      "name": "Claude Code Router",
      "category": "工具集成",
      "install": {
        "type": "npm",
        "package": "@musistudio/claude-code-router",
        "command": "npm install -g @musistudio/claude-code-router",
        "auto_setup": false
      },
      "config": {
        "env_vars": [
          {
            "name": "KIMI_API_KEY",
            "required": true,
            "get_url": "https://platform.moonshot.cn",
            "description": "Moonshot/Kimi API Key"
          }
        ],
        "files": [
          {
            "path": "~/.claude-code-router/config.json",
            "template": {
              "providers": {
                "kimi": {
                  "api_base_url": "https://api.moonshot.cn/v1/chat/completions",
                  "api_key": "${KIMI_API_KEY}"
                }
              }
            }
          }
        ],
        "systemd": {
          "service": "claude-code-router"
        }
      },
      "capabilities": ["api_proxy", "model_routing"],
      "dependencies": ["claude-code"],
      "multi_device_sync": false
    },
